---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import MovieGrid from '../components/MovieGrid.astro';
import ApiConfigError from '../components/ApiConfigError.astro';
import { fetchMovies, isApiConfigured } from '../lib/api';

const query = Astro.url.searchParams.get('q') ?? '';
const configured = isApiConfigured();
let error = false;
let movies = [];

if (configured) {
  try {
    movies = await fetchMovies(query || undefined);
  } catch {
    error = true;
  }
}
---

<BaseLayout title={query ? `${query} — GdzieDoKina.pl` : 'GdzieDoKina.pl'}>
  <section class="mb-8 text-center">
    <h1 class="mb-6 text-3xl font-bold text-gray-900 md:text-4xl">
      Znajdź filmy i seanse
    </h1>
    <div class="mx-auto flex justify-center">
      <SearchBar initialQuery={query} />
    </div>
  </section>

  <section>
    {!configured ? (
      <ApiConfigError />
    ) : error ? (
      <div class="rounded-lg border border-red-200 bg-red-50 p-6 text-center text-red-700">
        <p class="text-lg font-semibold">Nie udało się załadować filmów</p>
        <p class="mt-1 text-sm">Upewnij się, że serwer API działa i spróbuj ponownie.</p>
      </div>
    ) : (
      <MovieGrid movies={movies} />
    )}
  </section>
</BaseLayout>

<script>
  import '../scripts/movie-search';
</script>
