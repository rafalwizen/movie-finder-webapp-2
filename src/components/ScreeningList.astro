---
import type { Screening } from '../types';
import ScreeningCard from './ScreeningCard.astro';
import EmptyState from './EmptyState.astro';

interface Props {
  screenings: Screening[];
}

const { screenings } = Astro.props;
---

{screenings.length === 0 ? (
  <EmptyState message="Brak nadchodzących seansów dla tego filmu" />
) : (
  <div class="space-y-3" data-screening-list>
    {screenings.map((screening) => (
      <ScreeningCard screening={screening} />
    ))}
    <p data-no-results class="hidden text-center text-gray-400 py-8">
      Żaden seans nie pasuje do wybranych filtrów
    </p>
  </div>
)}
