---
/**
 * Notice shown when the API_BASE_URL environment variable is not set.
 * Surfaced to end users as a generic "service unavailable" message.
 */
---

<div class="rounded-lg border border-amber-200 bg-amber-50 p-6 text-center text-amber-800">
  <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-amber-100">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
      <line x1="12" y1="9" x2="12" y2="13" />
      <line x1="12" y1="17" x2="12.01" y2="17" />
    </svg>
  </div>
  <p class="text-lg font-semibold">Serwis tymczasowo niedostępny</p>
</div>
