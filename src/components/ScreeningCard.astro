---
import type { Screening } from '../types';
import ProviderBadge from './ProviderBadge.astro';
import { formatScreeningDatetime } from '../lib/api';

interface Props {
  screening: Screening;
}

const { screening } = Astro.props;
const formatted = formatScreeningDatetime(screening.screeningDatetime);
const location = [screening.cinemaCity, screening.cinemaAddress]
  .filter(Boolean)
  .join(', ');
---

<div
  class="flex flex-col gap-3 rounded-lg border border-gray-200 bg-white p-4 sm:flex-row sm:items-center sm:justify-between"
  data-screening-card
  data-city={screening.cinemaCity ?? ''}
  data-date={formatted.isoDate}
>
  <div class="flex-1">
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-lg font-semibold text-gray-900">{formatted.date}</span>
      <span class="text-lg font-bold text-blue-600">{formatted.time}</span>
    </div>
    <p class="mt-1 text-sm font-medium text-gray-700">{screening.cinemaName}</p>
    {location && (
      <p class="text-sm text-gray-500">{location}</p>
    )}
  </div>

  <div class="flex items-center gap-3">
    <ProviderBadge code={screening.providerCode} />
    {screening.screeningUrl ? (
      <a
        href={screening.screeningUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-blue-700"
      >
        Kup bilet
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
          <polyline points="15 3 21 3 21 9" />
          <line x1="10" y1="14" x2="21" y2="3" />
        </svg>
      </a>
    ) : (
      <span class="text-sm text-gray-400">Brak linku do rezerwacji</span>
    )}
  </div>
</div>
